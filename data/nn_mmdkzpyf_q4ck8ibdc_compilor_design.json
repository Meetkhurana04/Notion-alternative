  "id": "nn_mmdkzpyf_q4ck8ibdc",
  "title": "compilor design",
  "content": "<h1 data-end=\"184\" data-start=\"145\">Notes – Elimination of Left Recursion</h1>\n<h3 data-end=\"202\" data-start=\"186\">Introduction</h3>\n<ul data-end=\"324\" data-start=\"203\">\n<li data-end=\"287\" data-start=\"203\">\n<p data-end=\"287\" data-start=\"205\">Is session me <strong data-end=\"275\" data-start=\"219\">Left Recursion ko eliminate karne ke solved examples</strong> dekhenge.</p>\n</li>\n<li data-end=\"324\" data-start=\"288\">\n<p data-end=\"324\" data-start=\"290\">Chaliye start karte hain learning.</p>\n</li>\n</ul>\n<hr data-end=\"329\" data-start=\"326\">\n<h1 data-end=\"348\" data-start=\"331\">Session Outcome</h1>\n<ul data-end=\"437\" data-start=\"349\">\n<li data-end=\"437\" data-start=\"349\">\n<p data-end=\"437\" data-start=\"351\">Aaj hum <strong data-end=\"380\" data-start=\"359\">4 solved examples</strong> dekhenge jisme <strong data-end=\"424\" data-start=\"396\">Left Recursion eliminate</strong> kiya jayega.</p>\n</li>\n</ul>\n<hr data-end=\"442\" data-start=\"439\">\n<h1 data-end=\"455\" data-start=\"444\">Example 1</h1>\n<h3 data-end=\"477\" data-start=\"457\">Given Production</h3>\n<p data-end=\"491\" data-start=\"478\">P → P + Q | Q</p>\n<h3 data-end=\"516\" data-start=\"493\">Identify Components</h3>\n<ul data-end=\"662\" data-start=\"517\">\n<li data-end=\"553\" data-start=\"517\">\n<p data-end=\"553\" data-start=\"519\"><strong data-end=\"524\" data-start=\"519\">P</strong> = generic non-terminal <strong data-end=\"553\" data-start=\"548\">A</strong></p>\n</li>\n<li data-end=\"618\" data-start=\"554\">\n<p data-end=\"618\" data-start=\"556\">Right side me <strong data-end=\"616\" data-start=\"570\">P leftmost position par dubara aa raha hai</strong></p>\n</li>\n<li data-end=\"662\" data-start=\"619\">\n<p data-end=\"662\" data-start=\"621\">Isliye <strong data-end=\"657\" data-start=\"628\">Left Recursive Production</strong> hai.</p>\n</li>\n</ul>\n<h3 data-end=\"682\" data-start=\"664\">Alpha aur Beta</h3>\n<ul data-end=\"723\" data-start=\"683\">\n<li data-end=\"704\" data-start=\"683\">\n<p data-end=\"704\" data-start=\"685\"><strong data-end=\"704\" data-start=\"685\">α (alpha) = + Q</strong></p>\n</li>\n<li data-end=\"723\" data-start=\"705\">\n<p data-end=\"723\" data-start=\"707\"><strong data-end=\"723\" data-start=\"707\">β (beta) = Q</strong></p>\n</li>\n</ul>\n<h3 data-end=\"756\" data-start=\"725\">Left Recursion Removal Rule</h3>\n<p data-end=\"781\" data-start=\"757\">A → β A′<br data-end=\"768\" data-start=\"765\">\nA′ → α A′ | ε</p>\n<h3 data-end=\"797\" data-start=\"783\">Apply Rule</h3>\n<ul data-end=\"834\" data-start=\"798\">\n<li data-end=\"812\" data-start=\"798\">\n<p data-end=\"812\" data-start=\"800\"><strong data-end=\"812\" data-start=\"800\">P → Q P′</strong></p>\n</li>\n<li data-end=\"834\" data-start=\"813\">\n<p data-end=\"834\" data-start=\"815\"><strong data-end=\"834\" data-start=\"815\">P′ → + Q P′ | ε</strong></p>\n</li>\n</ul>\n<h3 data-end=\"846\" data-start=\"836\">Result</h3>\n<ul data-end=\"942\" data-start=\"847\">\n<li data-end=\"895\" data-start=\"847\">\n<p data-end=\"895\" data-start=\"849\">Ab <strong data-end=\"893\" data-start=\"852\">P′ rightmost position par aa raha hai</strong></p>\n</li>\n<li data-end=\"942\" data-start=\"896\">\n<p data-end=\"942\" data-start=\"898\">Isliye grammar <strong data-end=\"932\" data-start=\"913\">Right Recursive</strong> ban gaya.</p>\n</li>\n</ul>\n<hr data-end=\"947\" data-start=\"944\">\n<h1 data-end=\"960\" data-start=\"949\">Example 2</h1>\n<h3 data-end=\"979\" data-start=\"962\">Given Grammar</h3>\n<p data-end=\"998\" data-start=\"980\">S → S 0 S 1 S | 01</p>\n<h3 data-end=\"1018\" data-start=\"1000\">Identify Parts</h3>\n<ul data-end=\"1083\" data-start=\"1019\">\n<li data-end=\"1030\" data-start=\"1019\">\n<p data-end=\"1030\" data-start=\"1021\"><strong data-end=\"1030\" data-start=\"1021\">S = A</strong></p>\n</li>\n<li data-end=\"1083\" data-start=\"1031\">\n<p data-end=\"1083\" data-start=\"1033\">Right side me <strong data-end=\"1065\" data-start=\"1047\">S leftmost hai</strong> → Left Recursion.</p>\n</li>\n</ul>\n<h3 data-end=\"1103\" data-start=\"1085\">Alpha aur Beta</h3>\n<ul data-end=\"1134\" data-start=\"1104\">\n<li data-end=\"1121\" data-start=\"1104\">\n<p data-end=\"1121\" data-start=\"1106\"><strong data-end=\"1121\" data-start=\"1106\">α = 0 S 1 S</strong></p>\n</li>\n<li data-end=\"1134\" data-start=\"1122\">\n<p data-end=\"1134\" data-start=\"1124\"><strong data-end=\"1134\" data-start=\"1124\">β = 01</strong></p>\n</li>\n</ul>\n<h3 data-end=\"1155\" data-start=\"1136\">Convert Grammar</h3>\n<p data-end=\"1180\" data-start=\"1157\">Start Symbol:<br>\nS → 01 S′</p>\n<p data-end=\"1219\" data-start=\"1182\">New Non-terminal:<br>\nS′ → 0 S 1 S S′ | ε</p>\n<h3 data-end=\"1231\" data-start=\"1221\">Result</h3>\n<ul data-end=\"1306\" data-start=\"1232\">\n<li data-end=\"1267\" data-start=\"1232\">\n<p data-end=\"1267\" data-start=\"1234\"><strong data-end=\"1267\" data-start=\"1234\">S′ rightmost position par hai</strong></p>\n</li>\n<li data-end=\"1306\" data-start=\"1268\">\n<p data-end=\"1306\" data-start=\"1270\">Grammar <strong data-end=\"1297\" data-start=\"1278\">Right Recursive</strong> ho gaya.</p>\n</li>\n</ul>\n<hr data-end=\"1311\" data-start=\"1308\">\n<h1 data-end=\"1324\" data-start=\"1313\">Example 3</h1>\n<h3 data-end=\"1343\" data-start=\"1326\">Given Grammar</h3>\n<p data-end=\"1373\" data-start=\"1344\">A → ( B ) | B<br data-end=\"1360\" data-start=\"1357\">\nB → B * A | A</p>\n<h3 data-end=\"1390\" data-start=\"1375\">Observation</h3>\n<ul data-end=\"1496\" data-start=\"1391\">\n<li data-end=\"1445\" data-start=\"1391\">\n<p data-end=\"1445\" data-start=\"1393\"><strong data-end=\"1417\" data-start=\"1393\">First production (A)</strong> me left recursion nahi hai.</p>\n</li>\n<li data-end=\"1496\" data-start=\"1446\">\n<p data-end=\"1496\" data-start=\"1448\"><strong data-end=\"1473\" data-start=\"1448\">Second production (B)</strong> me left recursion hai.</p>\n</li>\n</ul>\n<h3 data-end=\"1521\" data-start=\"1498\">Identify Components</h3>\n<ul data-end=\"1577\" data-start=\"1522\">\n<li data-end=\"1551\" data-start=\"1522\">\n<p data-end=\"1551\" data-start=\"1524\"><strong data-end=\"1551\" data-start=\"1524\">B = A type non-terminal</strong></p>\n</li>\n<li data-end=\"1565\" data-start=\"1552\">\n<p data-end=\"1565\" data-start=\"1554\"><strong data-end=\"1565\" data-start=\"1554\">α = * A</strong></p>\n</li>\n<li data-end=\"1577\" data-start=\"1566\">\n<p data-end=\"1577\" data-start=\"1568\"><strong data-end=\"1577\" data-start=\"1568\">β = A</strong></p>\n</li>\n</ul>\n<h3 data-end=\"1598\" data-start=\"1579\">Convert Grammar</h3>\n<p data-end=\"1610\" data-start=\"1600\">B → A B′</p>\n<p data-end=\"1627\" data-start=\"1612\">B′ → * A B′ | ε</p>\n<h3 data-end=\"1655\" data-start=\"1629\">Final Modified Grammar</h3>\n<p data-end=\"1698\" data-start=\"1656\">A → ( B ) | B<br data-end=\"1672\" data-start=\"1669\">\nB → A B′<br data-end=\"1683\" data-start=\"1680\">\nB′ → * A B′ | ε</p>\n<hr data-end=\"1703\" data-start=\"1700\">\n<h1 data-end=\"1731\" data-start=\"1705\">Example 4 (General Case)</h1>\n<h3 data-end=\"1750\" data-start=\"1733\">Given Grammar</h3>\n<p data-end=\"1793\" data-start=\"1751\">A → Aα1 | Aα2 | Aα3 | … | β1 | β2 | β3 | …</p>\n<h3 data-end=\"1822\" data-start=\"1795\">Identify Left Recursion</h3>\n<ul data-end=\"1931\" data-start=\"1823\">\n<li data-end=\"1881\" data-start=\"1823\">\n<p data-end=\"1881\" data-start=\"1825\"><strong data-end=\"1842\" data-start=\"1825\">Aα1, Aα2, Aα3</strong> wali productions left recursive hain</p>\n</li>\n<li data-end=\"1931\" data-start=\"1882\">\n<p data-end=\"1931\" data-start=\"1884\">Kyunki <strong data-end=\"1930\" data-start=\"1891\">A leftmost position par aa raha hai</strong>.</p>\n</li>\n</ul>\n<h3 data-end=\"1952\" data-start=\"1933\">Convert Grammar</h3>\n<p data-end=\"1983\" data-start=\"1954\">A → β1 A′ | β2 A′ | β3 A′ | …</p>\n<p data-end=\"2019\" data-start=\"1985\">A′ → α1 A′ | α2 A′ | α3 A′ | … | ε</p>\n<h3 data-end=\"2031\" data-start=\"2021\">Result</h3>\n<ul data-end=\"2107\" data-start=\"2032\">\n<li data-end=\"2067\" data-start=\"2032\">\n<p data-end=\"2067\" data-start=\"2034\"><strong data-end=\"2067\" data-start=\"2034\">A′ rightmost position par hai</strong></p>\n</li>\n<li data-end=\"2107\" data-start=\"2068\">\n<p data-end=\"2107\" data-start=\"2070\">Grammar <strong data-end=\"2097\" data-start=\"2078\">Right Recursive</strong> ban gaya.</p>\n</li>\n</ul>\n<hr data-end=\"2112\" data-start=\"2109\">\n<h1 data-end=\"2133\" data-start=\"2114\">Important Concept</h1>\n<ul data-end=\"2327\" data-start=\"2135\">\n<li data-end=\"2183\" data-start=\"2135\">\n<p data-end=\"2183\" data-start=\"2137\"><strong data-end=\"2183\" data-start=\"2137\">Left Recursion eliminate karna zaroori hai</strong></p>\n</li>\n<li data-end=\"2262\" data-start=\"2184\">\n<p data-end=\"2262\" data-start=\"2186\">Kyunki <strong data-end=\"2213\" data-start=\"2193\">Top-Down Parsers</strong> left recursive grammars ko handle nahi kar pate.</p>\n</li>\n<li data-end=\"2327\" data-start=\"2263\">\n<p data-end=\"2327\" data-start=\"2265\">Wo <strong data-end=\"2326\" data-start=\"2268\">confuse ho jaate hain aur grammar reject kar dete hain</strong>.</p>\n</li>\n</ul>\n<hr data-end=\"2332\" data-start=\"2329\">\n<h1 data-end=\"2351\" data-start=\"2334\">Session Summary</h1>\n<p data-end=\"2372\" data-start=\"2352\">Is session me humne:</p>\n<ul data-end=\"2451\" data-start=\"2373\">\n<li data-end=\"2405\" data-start=\"2373\">\n<p data-end=\"2405\" data-start=\"2375\"><strong data-end=\"2405\" data-start=\"2375\">Left Recursion elimination</strong></p>\n</li>\n<li data-end=\"2429\" data-start=\"2406\">\n<p data-end=\"2429\" data-start=\"2408\"><strong data-end=\"2429\" data-start=\"2408\">4 solved examples</strong></p>\n</li>\n<li data-end=\"2451\" data-start=\"2430\">\n<p data-end=\"2451\" data-start=\"2432\"><strong data-end=\"2451\" data-start=\"2432\">General formula</strong></p>\n</li>\n</ul>\n<p data-end=\"2460\" data-start=\"2453\">seekha.</p><p data-end=\"2460\" data-start=\"2453\"><br></p><p data-end=\"2460\" data-start=\"2453\">hello</p><p data-end=\"2460\" data-start=\"2453\">hello</p><p data-end=\"2460\" data-start=\"2453\"><br></p>\n\n",
